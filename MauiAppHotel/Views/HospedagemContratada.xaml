<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.HospedagemContratada"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Gray100}">

    <VerticalStackLayout VerticalOptions="CenterAndExpand">

        <Label Text="{Binding QuartoSelecionado.Descricao}" 
               TextColor="{StaticResource Primary}" 
               FontFamily="Kalam"
               FontSize="36"
               Margin="0,20,0,10"
               HorizontalTextAlignment="Center"/>

        <Frame Margin="10" 
               CornerRadius="15"
               BackgroundColor="White"
               BorderColor="#EEEEEE"
               HasShadow="True"
               Padding="15">
            
            <HorizontalStackLayout HorizontalOptions="CenterAndExpand"
                    Spacing="60">
                
                <HorizontalStackLayout>
                    <Label Text="Adultos: " />
                    <Label Text="{Binding QntAdultos }" TextColor="{StaticResource Primary}"/>
                </HorizontalStackLayout>
                
                <HorizontalStackLayout>
                    <Label Text="Crianças: " />
                    <Label Text="{Binding QntCriancas }" TextColor="{StaticResource Primary}"/>
                </HorizontalStackLayout>
                
            </HorizontalStackLayout>
        </Frame>

        <Frame Margin="10"
               CornerRadius="15"
               BackgroundColor="White"
               BorderColor="#EEEEEE"
               HasShadow="True"
               Padding="15">
            
            <Grid ColumnDefinitions="*, *, *"
                  RowDefinitions="Auto, Auto">
                <Label Grid.Row="0" Grid.Column="0" Text="Check-in:"/>
                <Label Grid.Row="0" Grid.Column="1" Text="Check-out:"/>
                <Label Grid.Row="0" Grid.Column="2" Text="Estadia:"/>

                <Label Grid.Row="1" Grid.Column="0" 
                       Text="{Binding DataCheckin, StringFormat='{}{0:dd/MM/yyyy}'}"
                       TextColor="{StaticResource Primary}"/>
                
                <Label Grid.Row="1" Grid.Column="1" 
                       Text="{Binding DataCheckout,StringFormat='{}{0:dd/MM/yyyy}'}"
                       TextColor="{StaticResource Primary}"/>
                
                <Label Grid.Row="1" Grid.Column="2" 
                       Text="{Binding Estadia}"
                       TextColor="{StaticResource Primary}"/>
            </Grid>
        </Frame>

        <Frame Margin="10"
               CornerRadius="15"
               BackgroundColor="White"
               BorderColor="#EEEEEE"
               HasShadow="True"
               Padding="15">

            <HorizontalStackLayout HorizontalOptions="CenterAndExpand">
                <Label Text="Valor Total:" />
                <Label Text="{Binding ValorTotal, StringFormat='{}{0:c}'}" 
                       TextColor="{StaticResource Primary}"/>
            </HorizontalStackLayout>
        </Frame>

        <Button Text="Voltar" 
                HorizontalOptions="Center"
                Clicked="Button_Clicked" />


    </VerticalStackLayout>
    
    
</ContentPage>