<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.ContratacaoHospedagem"
             Title="ContratacaoHospedagem"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Gray100}">

    <VerticalStackLayout VerticalOptions="Fill"
                         Padding="10"
                         Spacing="10">
        
        <Label   Text="Hotel Paradise"
                 FontFamily="Kalam"
                 FontSize="42"
                 HorizontalOptions="Center"
                 TextColor="{StaticResource Primary}"/>

        <Label  Text="Reserve sua Hospedagem"
                FontSize="16"
                HorizontalOptions="Center"
                TextColor="Gray"/>

        <Frame Padding="15"
               Margin="10"
               CornerRadius="20"
               BackgroundColor="White"
               BorderColor="#EAEAEA"
               HasShadow="True">

            <VerticalStackLayout>
                <Grid RowDefinitions="Auto, Auto"
                      ColumnDefinitions="*, *, 2*">

                    <Label Grid.Row="0" Grid.Column="0"
                           Text="Adultos:" />

                    <Label Grid.Row="0" Grid.Column="1"
                           TextColor="{StaticResource Primary}"
                           Text="{Binding Value}"
                           BindingContext="{Reference stp_adultos}"/>

                    <Stepper Grid.Row="0" Grid.Column="2"
                             x:Name="stp_adultos"
                             Minimum="0"
                             Maximum="10"
                             Increment="1"/>

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="Crianças:" />

                    <Label Grid.Row="1" Grid.Column="1"
                           TextColor="{StaticResource Primary}"
                           Text="{Binding Value}"
                           BindingContext="{Reference stp_criancas}"/>

                    <Stepper Grid.Row="1" Grid.Column="2"
                             x:Name="stp_criancas"
                             Minimum="0"
                             Maximum="10"
                             Increment="1"/>

                </Grid>

                <Frame Padding="10" 
                       Margin="10"
                       BackgroundColor="White"
                       BorderColor="LightGray"
                       CornerRadius="10"
                       HasShadow="True">

                    <VerticalStackLayout>
                        
                       <Label Text="Escolha sua Suíte"
                              Padding="5"
                              FontAttributes="Bold"
                              FontSize="18"
                              TextColor="{StaticResource Primary}"/>

                        <Picker x:Name="pck_quarto"
                                Title="Selecione sua acomadação"
                                Background="#F8F8F8"
                                HeightRequest="60"
                                ItemDisplayBinding="{Binding Descricao}"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="10"
                       Margin="10"
                       BorderColor="{StaticResource Gray100}"
                       BackgroundColor="white">
                    <VerticalStackLayout Spacing="10">
                        
                        <Label Text="Período de Estadia"
                               Padding="5"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="{StaticResource Primary}"/>

                        <HorizontalStackLayout 
                            HorizontalOptions="Fill"
                            Spacing="20">
                            
                        <Label Text="Check-in:" />
                            <DatePicker x:Name="dtpck_checkin"
                                        HorizontalOptions="Fill"
                                        HeightRequest="45"
                                        DateSelected="dtpck_checkin_DateSelected"
                                        Format="dd/MM/yyyy" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout 
                            HorizontalOptions="Fill"
                            Spacing="12">
                            
                        <Label Text="Check-out:" />
                            <DatePicker x:Name="dtpck_checkout"
                                        HorizontalOptions="Fill"
                                        HeightRequest="45"
                                        Format="dd/MM/yyyy" />

                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <Button Text="Reservar Agora"
                        HeightRequest="30"
                        CornerRadius="15"
                        FontAttributes="Bold"
                        FontSize="18"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        Margin="0,0,0,15"
                        HorizontalOptions="Fill"
                        Clicked="Button_Clicked"/>

                <Button Text="Sobre"
                        FontSize="12"
                        TextColor="Gray"
                        BackgroundColor="Transparent"
                        HorizontalOptions="End"
                        WidthRequest="80"
                        HeightRequest="25"
                        Clicked="Sobre_Clicked"/>

            </VerticalStackLayout>
                
        </Frame>
    </VerticalStackLayout>
    
</ContentPage>